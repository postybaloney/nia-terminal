# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://patent:changeme@localhost:5432/patent_intel
POSTGRES_PASSWORD=changeme

# ── LLM Backend ─────────────────────────────────────────────────────────────
# Choose ONE backend and fill in only that key.
#
# Option 1: Groq (FREE — recommended)
#   Sign up at https://console.groq.com — no credit card needed
#   Default model: llama-3.3-70b-versatile
LLM_BACKEND=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=gsk_...

# Option 2: Google Gemini (FREE tier)
#   Get key at https://aistudio.google.com — no billing needed
# LLM_BACKEND=gemini
# LLM_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=AIza...

# Option 3: Ollama (FREE, fully local — no internet, no account)
#   Install: https://ollama.com  then run: ollama pull llama3.2
# LLM_BACKEND=ollama
# LLM_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# Option 4: Hugging Face (FREE tier, slow)
#   Get token at https://huggingface.co/settings/tokens
# LLM_BACKEND=huggingface
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# HUGGINGFACE_TOKEN=hf_...

# Option 5: Anthropic Claude (PAID)
# LLM_BACKEND=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...

# ── Patent Sources ───────────────────────────────────────────────────────────
# PatentsView requires no credentials — works out of the box.

# EPO OPS (European patents) — free, register at https://developers.epo.org
EPO_CLIENT_ID=
EPO_CLIENT_SECRET=

# Lens.org — free tier, get key at https://lens.org/lens/user/subscriptions
LENS_API_KEY=

# Google BigQuery — optional, for bulk analytics
BIGQUERY_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Notifications ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_EMAIL_TO=

# ── Search config ────────────────────────────────────────────────────────────
SEARCH_QUERIES=neurotech neural stimulation brain electrode,brain computer interface cortical,neural implant deep brain stimulation,neuroprosthetics motor cortex,medical device biosensor implantable
BACKFILL_FROM=2022-01-01

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_CRON=0 2 * * *
PER_PAGE=50
ANALYSIS_MIN_NEW=5

# ── Thesis config ────────────────────────────────────────────────────────────
# Comma-separated search queries for thesis ingestion
THESIS_QUERIES=neural interface hardware,brain computer interface,implantable medical device,neuroprosthetics,medical signal processing deep learning,neuromorphic computing,biosensor wearable,surgical robotics,medical image segmentation

# Earliest year to include (theses older than this are filtered out)
THESIS_SINCE_YEAR=2018

# Optional extra keywords for hardware/software relevance filter (comma-separated)
# Add domain-specific terms your team cares about
THESIS_EXTRA_KEYWORDS=optogenetics,closed loop stimulation,spike detection,patch clamp

# EThOS API key — optional, increases rate limits for UK thesis search
# Register free at https://ethos.bl.uk/Register.do
ETHOS_API_KEY=
